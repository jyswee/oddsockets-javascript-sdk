{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "maxNodeModuleJsDepth": 0,
    "suppressImplicitAnyIndexErrors": true,
    "noEmitOnError": false
  },
  "include": [
    "src/**/*",
    "package.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "examples",
    "docs",
    "swagger",
    "**/*.test.js",
    "**/*.spec.js",
    "config-loader.js",
    "publish_all.sh",
    "*.md"
  ]
}
